# Local dev data directory
.deco

# `helm dependency update` caches local file:// subcharts as .tgz next to
# the unpacked dir. The unpacked tree under deploy/helm/charts/agent-sandbox/
# is the source of truth (vendored from kubernetes-sigs/agent-sandbox via
# vendor.sh) and `helm package` consumes it directly — the .tgz is
# redundant and would just drift. Remote deps' .tgz cache (nats-*.tgz,
# opentelemetry-collector-*.tgz) is still tracked because those repos
# aren't vendored locally.
deploy/helm/charts/agent-sandbox-*.tgz
