# Claude-enabled variant of mesh-sandbox.
# Build: docker build -t mesh-sandbox:claude -f Dockerfile.claude packages/mesh-plugin-user-sandbox/image
#
# Extends mesh-sandbox:local with the claude-code CLI baked in, installed via
# bun (faster than npm and already on PATH from the base). Used by the
# decopilot claude-code sandbox path so the first turn doesn't pay a ~10s npm
# install hit. Adds ~80MB over the plain image.
FROM mesh-sandbox:local

RUN bun install -g @anthropic-ai/claude-code@2.1.116 \
  && ln -sf /root/.bun/bin/claude /usr/local/bin/claude \
  && /usr/local/bin/claude --version
