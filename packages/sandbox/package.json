{
  "name": "@decocms/sandbox",
  "version": "0.3.9",
  "type": "module",
  "description": "Sandbox runner for isolated per-user containerised tool execution",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build daemon/entry.ts --target=bun --outfile=daemon/dist/daemon.js --external node-pty && bun run build:cli",
    "build:cli": "bun build cli/sandbox.ts --target=bun --outfile=cli/dist/sandbox.js",
    "dev:daemon": "bun run --watch daemon/entry.ts"
  },
  "exports": {
    "./shared": "./shared.ts",
    "./runner": "./server/runner/index.ts",
    "./runner/agent-sandbox": "./server/runner/agent-sandbox/index.ts",
    "./runner/freestyle": "./server/runner/freestyle/index.ts"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "node-pty": "^1.0.0"
  },
  "optionalDependencies": {
    "@freestyle-sh/with-bun": "^0.2.12",
    "@freestyle-sh/with-deno": "^0.0.4",
    "@freestyle-sh/with-nodejs": "^0.2.9",
    "freestyle-sandboxes": "^0.1.46"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
