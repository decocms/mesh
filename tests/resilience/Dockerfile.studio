FROM oven/bun:1-slim

RUN apt-get update && apt-get install -y unzip bash && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy everything and install
COPY . .
RUN bun install

# Build client + server
RUN bun run --cwd apps/mesh build:client && bun run --cwd apps/mesh build:server

WORKDIR /app/apps/mesh

RUN mkdir -p /app/data

# Create entrypoint that runs migrations then starts server
RUN printf '#!/bin/bash\nset -e\ncd /app/apps/mesh\necho "Running migrations..."\nbun run migrate 2>&1\necho "Starting server..."\nexec bun run src/index.ts\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

EXPOSE 3000

ENV NODE_ENV=production

CMD ["/app/entrypoint.sh"]
